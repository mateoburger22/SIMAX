# Copiá este archivo como  .env.local  y completá con tus valores reales.
# .env.local está en .gitignore: NUNCA se sube al repo.
#
# El prefijo NEXT_PUBLIC_ hace que la variable viaje también al navegador.
# Las que NO lo tienen son SECRETAS y solo existen en el server.

# --- Supabase (Project Settings -> API) ---
# La "anon key" es pública por diseño: lo que protege los datos es RLS,
# no esconder esta clave.
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-aca

# Service role: SALTEA RLS. Solo la usan el webhook de MP, el checkout y
# /api/contacto, siempre server-side. Jamás con NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key-aca

# --- Mercado Pago (panel de desarrolladores -> credenciales de PRUEBA) ---
MP_ACCESS_TOKEN=TEST-tu-access-token-aca

# Clave secreta del webhook (panel de MP -> Webhooks -> Clave secreta).
# Con ella verificamos la firma x-signature de cada notificación.
MP_WEBHOOK_SECRET=tu-webhook-secret-aca

# --- Sitio ---
# URL pública: MP la usa para back_urls y notification_url.
# En local con webhook real hace falta un túnel (ej. ngrok).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
